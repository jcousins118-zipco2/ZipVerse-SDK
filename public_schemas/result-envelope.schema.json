{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/zipverse/result-envelope.schema.json",
  "title": "ZipVerse Public Result Envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task_id",
    "status",
    "summary"
  ],
  "properties": {
    "schema_version": {
      "const": "0.1"
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "accepted",
        "rejected",
        "approval_required",
        "running",
        "completed",
        "failed",
        "held"
      ]
    },
    "summary": {
      "type": "string"
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "reference"],
        "properties": {
          "type": { "type": "string", "minLength": 1 },
          "reference": { "type": "string", "minLength": 1 }
        }
      },
      "default": []
    },
    "errors": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
