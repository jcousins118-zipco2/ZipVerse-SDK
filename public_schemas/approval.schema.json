{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/zipverse/approval.schema.json",
  "title": "ZipVerse Public Approval",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "approval_id",
    "task_id",
    "decision",
    "approved_by",
    "approved_at"
  ],
  "properties": {
    "schema_version": {
      "const": "0.1"
    },
    "approval_id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "decision": {
      "enum": ["approved", "rejected"]
    },
    "approved_by": {
      "type": "string",
      "minLength": 1
    },
    "approved_at": {
      "type": "string",
      "format": "date-time"
    },
    "scope_hash": {
      "type": "string",
      "minLength": 1
    },
    "notes": {
      "type": "string"
    }
  }
}
